{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows Debug (MinGW)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "cmake/toolchains/mingw-w64-x86_64.cmake"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows Release (MinGW)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "cmake/toolchains/mingw-w64-x86_64.cmake"
      }
    },
    {
      "name": "ios-iphone-simulator-debug",
      "displayName": "iOS iPhone Simulator Debug",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/ios-iphone-simulator-debug",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "17.0",
        "SIMPLICITY_ENGINE_IOS_DEVICE_FAMILY": "1"
      }
    },
    {
      "name": "ios-iphone-simulator-release",
      "displayName": "iOS iPhone Simulator Release",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/ios-iphone-simulator-release",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "17.0",
        "SIMPLICITY_ENGINE_IOS_DEVICE_FAMILY": "1"
      }
    },
    {
      "name": "ios-ipad-simulator-debug",
      "displayName": "iOS iPad Simulator Debug",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/ios-ipad-simulator-debug",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "17.0",
        "SIMPLICITY_ENGINE_IOS_DEVICE_FAMILY": "2"
      }
    },
    {
      "name": "ios-ipad-simulator-release",
      "displayName": "iOS iPad Simulator Release",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/ios-ipad-simulator-release",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "17.0",
        "SIMPLICITY_ENGINE_IOS_DEVICE_FAMILY": "2"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release"
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release"
    },
    {
      "name": "ios-iphone-simulator-debug",
      "configurePreset": "ios-iphone-simulator-debug",
      "targets": [
        "hello_pixel"
      ]
    },
    {
      "name": "ios-iphone-simulator-release",
      "configurePreset": "ios-iphone-simulator-release",
      "targets": [
        "hello_pixel"
      ]
    },
    {
      "name": "ios-ipad-simulator-debug",
      "configurePreset": "ios-ipad-simulator-debug",
      "targets": [
        "hello_pixel"
      ]
    },
    {
      "name": "ios-ipad-simulator-release",
      "configurePreset": "ios-ipad-simulator-release",
      "targets": [
        "hello_pixel"
      ]
    }
  ]
}
